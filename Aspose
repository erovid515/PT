import aspose.words as aw

INPUT_FILE = "Pentest_Report.docx"
OUTPUT_FILE = "Medium_Severity.docx"

START_TEXT = "Medium Severity"
END_TEXT = "Low Severity"

doc = aw.Document(INPUT_FILE)

start_node = None
end_node = None

# Find start and end headings
for para in doc.get_child_nodes(aw.NodeType.PARAGRAPH, True):
    para = para.as_paragraph()

    style = para.paragraph_format.style

    # Only consider headings
    if not style.name.startswith("Heading"):
        continue

    text = para.to_string(aw.SaveFormat.TEXT).strip()

    if start_node is None:
        if START_TEXT.lower() in text.lower():
            start_node = para
    else:
        if END_TEXT.lower() in text.lower():
            end_node = para
            break

if start_node is None:
    raise Exception("Medium Severity heading not found.")

if end_node is None:
    raise Exception("Low Severity heading not found.")

# Create output document
new_doc = aw.Document()
new_doc.remove_all_children()

section = aw.Section(new_doc)
new_doc.append_child(section)

body = aw.Body(new_doc)
section.append_child(body)

# Copy every node between start and end
node = start_node

while node is not None and node != end_node:
    body.append_child(new_doc.import_node(node, True))
    node = node.next_sibling

new_doc.save(OUTPUT_FILE)

print("Done!")
