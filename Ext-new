"""
Extract everything between a "Medium Severity" heading and the next
"Low Severity" heading from every .docx in the current folder, and combine
all of them into a single output .docx - preserving images, tables,
bullet/numbered lists, and formatting.

Usage:
    python ext.py
    (it will scan the current folder and ask you for an output filename)

Optional: override the start/end heading text:
    python ext.py "High Severity" "Medium Severity"

Requires: pip install python-docx
"""

import sys
import os
import io
import re
import glob
import copy
from docx import Document
from docx.oxml.ns import qn


def natural_sort_key(path):
    """Sort the way Windows File Explorer does: case-insensitive, and
    numeric chunks compared by value (so 'file2' sorts before 'file10')."""
    name = os.path.basename(path)
    return [int(chunk) if chunk.isdigit() else chunk.lower()
            for chunk in re.split(r'(\d+)', name)]


def get_heading_level(paragraph):
    style_name = paragraph.style.name if paragraph.style else ""
    if style_name.lower().startswith("heading"):
        digits = "".join(ch for ch in style_name if ch.isdigit())
        return int(digits) if digits else 1
    if style_name.lower() == "title":
        return 0
    return None


def get_section_elements(docx_path, start_text, end_text):
    """Return (doc, elements): the source Document object and the list of
    XML elements (paragraphs/tables) between the heading matching start_text
    and the next heading matching end_text (exclusive of both boundaries'
    surrounding content, inclusive of the start heading itself).
    If end_text is never found after start_text, extraction runs to the end
    of the document. Returns (doc, None) if start_text is never found."""
    doc = Document(docx_path)
    body = doc.element.body

    children = [c for c in body.iterchildren()]
    if children and children[-1].tag == qn("w:sectPr"):
        children = children[:-1]

    para_map = {p._p: p for p in doc.paragraphs}

    start_idx = None
    end_idx = len(children)  # default: end of document

    for i, el in enumerate(children):
        if el.tag == qn("w:p") and el in para_map:
            para = para_map[el]
            text = para.text.strip()
            level = get_heading_level(para)

            if start_idx is None:
                if level is not None and start_text.lower() in text.lower():
                    start_idx = i
                    continue

            if start_idx is not None and level is not None:
                if end_text.lower() in text.lower():
                    end_idx = i
                    break

    if start_idx is None:
        return doc, None

    return doc, children[start_idx:end_idx]


R_NS = "http://schemas.openxmlformats.org/officeDocument/2006/relationships"


def copy_relationships(src_doc, dest_doc, element):
    """Find ANY relationship-carrying reference inside `element` (images,
    hyperlinks, embedded objects/charts, etc. - anything using r:id, r:embed,
    or r:link) and copy the underlying relationship + part into dest_doc,
    then rewrite the reference to point at the new copy. This prevents
    'unreadable content' errors caused by references to relationships that
    only existed in the original source file."""
    r_attrs = [qn("r:id"), qn("r:embed"), qn("r:link")]

    for el in element.iter():
        for attr in r_attrs:
            old_rid = el.get(attr)
            if not old_rid:
                continue
            try:
                rel = src_doc.part.rels[old_rid]
            except KeyError:
                continue

            try:
                if rel.is_external:
                    new_rid = dest_doc.part.relate_to(
                        rel.target_ref, rel.reltype, is_external=True
                    )
                else:
                    new_rid = dest_doc.part.relate_to(rel.target_part, rel.reltype)
            except Exception:
                continue

            el.set(attr, new_rid)


def strip_unsupported_references(element):
    """Remove footnote/endnote references and mid-document section breaks
    from copied content. Footnotes/endnotes require copying and remapping
    an entire separate part (rarely worth it for extracted excerpts), and a
    mid-document sectPr can reference headers/footers that don't exist in
    the destination - both are common causes of 'unreadable content'."""
    for tag in (qn("w:footnoteReference"), qn("w:endnoteReference")):
        for ref in list(element.iter(tag)):
            ref.getparent().remove(ref)

    # A sectPr nested inside a paragraph's pPr marks a mid-document section
    # break (e.g. a landscape page for a wide table) - strip just the break,
    # keep the paragraph and its text.
    for pPr in list(element.iter(qn("w:pPr"))):
        sect_pr = pPr.find(qn("w:sectPr"))
        if sect_pr is not None:
            pPr.remove(sect_pr)

    # Bookmarks can end up unbalanced once content is sliced out of context
    # (a bookmarkStart with no matching bookmarkEnd, or vice versa). They're
    # only used for TOC/cross-reference navigation, so it's safe to drop them.
    for tag in (qn("w:bookmarkStart"), qn("w:bookmarkEnd")):
        for bm in list(element.iter(tag)):
            bm.getparent().remove(bm)

    # Numbered/bulleted list references (w:numPr) point at list definitions
    # in the SOURCE document's numbering part. Rather than copying and
    # remapping those definitions, just drop the reference - the paragraph
    # text stays, it just won't render with a bullet/number.
    for numPr in list(element.iter(qn("w:numPr"))):
        numPr.getparent().remove(numPr)



def batch_extract(folder, start_text, end_text, output_path):
    output_name = os.path.basename(output_path)
    files = sorted(glob.glob(os.path.join(folder, "*.docx")), key=natural_sort_key)
    files = [f for f in files if not os.path.basename(f).startswith("~$")]
    files = [f for f in files if os.path.basename(f) != output_name]

    if not files:
        print(f"No .docx files found in {folder}")
        sys.exit(1)

    master = Document()
    master_body = master.element.body
    sect_pr = master_body.find(qn("w:sectPr"))

    found_count = 0
    missing = []

    for f in files:
        src_doc, elements = get_section_elements(f, start_text, end_text)
        filename = os.path.basename(f)

        if elements is None:
            missing.append(filename)
            continue

        found_count += 1

        marker = master.add_paragraph()
        run = marker.add_run(f"Source report: {filename}")
        run.bold = True

        for el in elements:
            new_el = copy.deepcopy(el)
            strip_unsupported_references(new_el)
            copy_relationships(src_doc, master, new_el)
            if sect_pr is not None:
                sect_pr.addprevious(new_el)
            else:
                master_body.append(new_el)

        master.add_paragraph()

    master.save(output_path)

    print(f"\nDone. Extracted from {found_count}/{len(files)} files.")
    if missing:
        print(f"\nNo '{start_text}' heading found in {len(missing)} file(s):")
        for m in missing:
            print(f"  - {m}")
    print(f"\nSaved combined document to: {output_path}")


if __name__ == "__main__":
    start_text = sys.argv[1] if len(sys.argv) > 1 else "Medium Severity"
    end_text = sys.argv[2] if len(sys.argv) > 2 else "Low Severity"

    output_name = input("Enter output filename (e.g. Combined_Medium_Severity.docx): ").strip()
    if not output_name:
        output_name = "Combined_Output.docx"
    if not output_name.lower().endswith(".docx"):
        output_name += ".docx"

    batch_extract(".", start_text, end_text, output_name)
