"""
Extract everything between a "Medium Severity" heading and the next
"Low Severity" heading from every .docx in the current folder, and combine
all of them into a single output .docx - preserving images, tables,
bullet/numbered lists, and formatting.

Usage:
    python ext.py
    (it will scan the current folder and ask you for an output filename)

Optional: override the start/end heading text:
    python ext.py "High Severity" "Medium Severity"

Requires: pip install python-docx
"""

import sys
import os
import io
import glob
import copy
from docx import Document
from docx.oxml.ns import qn


def get_heading_level(paragraph):
    style_name = paragraph.style.name if paragraph.style else ""
    if style_name.lower().startswith("heading"):
        digits = "".join(ch for ch in style_name if ch.isdigit())
        return int(digits) if digits else 1
    if style_name.lower() == "title":
        return 0
    return None


def get_section_elements(docx_path, start_text, end_text):
    """Return (doc, elements): the source Document object and the list of
    XML elements (paragraphs/tables) between the heading matching start_text
    and the next heading matching end_text (exclusive of both boundaries'
    surrounding content, inclusive of the start heading itself).
    If end_text is never found after start_text, extraction runs to the end
    of the document. Returns (doc, None) if start_text is never found."""
    doc = Document(docx_path)
    body = doc.element.body

    children = [c for c in body.iterchildren()]
    if children and children[-1].tag == qn("w:sectPr"):
        children = children[:-1]

    para_map = {p._p: p for p in doc.paragraphs}

    start_idx = None
    end_idx = len(children)  # default: end of document

    for i, el in enumerate(children):
        if el.tag == qn("w:p") and el in para_map:
            para = para_map[el]
            text = para.text.strip()
            level = get_heading_level(para)

            if start_idx is None:
                if level is not None and start_text.lower() in text.lower():
                    start_idx = i
                    continue

            if start_idx is not None and level is not None:
                if end_text.lower() in text.lower():
                    end_idx = i
                    break

    if start_idx is None:
        return doc, None

    return doc, children[start_idx:end_idx]


def copy_images(src_doc, dest_doc, element):
    """Re-embed any images found inside `element` into dest_doc, and rewrite
    the reference so it points at the new copy instead of the (missing)
    original relationship."""
    for blip in element.iter(qn("a:blip")):
        embed_id = blip.get(qn("r:embed"))
        if not embed_id:
            continue
        try:
            image_part = src_doc.part.related_parts[embed_id]
        except KeyError:
            continue
        image_bytes = io.BytesIO(image_part.blob)
        new_rid, _ = dest_doc.part.get_or_add_image(image_bytes)
        blip.set(qn("r:embed"), new_rid)


def _get_numbering_root(doc):
    """Return the <w:numbering> root element for a document, creating the
    numbering part if the document doesn't have one yet."""
    return doc.part.numbering_part.element


def _insert_abstract_num(root, new_el):
    """abstractNum elements must all precede num elements per the schema."""
    existing = root.findall(qn("w:abstractNum"))
    if existing:
        existing[-1].addnext(new_el)
    else:
        root.insert(0, new_el)


def copy_numbering(src_doc, dest_doc, element, num_id_map):
    """Copy any bullet/numbered-list definitions referenced inside `element`
    from src_doc into dest_doc, remapping numIds so lists from different
    source reports never collide, then rewrite the references."""
    numPr_list = list(element.iter(qn("w:numPr")))
    if not numPr_list:
        return

    src_root = _get_numbering_root(src_doc)
    dest_root = _get_numbering_root(dest_doc)

    for numPr in numPr_list:
        numId_el = numPr.find(qn("w:numId"))
        if numId_el is None:
            continue
        old_num_id = numId_el.get(qn("w:val"))
        if old_num_id is None:
            continue

        key = (id(src_doc), old_num_id)
        if key in num_id_map:
            numId_el.set(qn("w:val"), num_id_map[key])
            continue

        src_num = None
        for num_el in src_root.findall(qn("w:num")):
            if num_el.get(qn("w:numId")) == old_num_id:
                src_num = num_el
                break
        if src_num is None:
            continue

        abstract_ref = src_num.find(qn("w:abstractNumId"))
        abstract_num_id = abstract_ref.get(qn("w:val")) if abstract_ref is not None else None

        src_abstract = None
        if abstract_num_id is not None:
            for a_el in src_root.findall(qn("w:abstractNum")):
                if a_el.get(qn("w:abstractNumId")) == abstract_num_id:
                    src_abstract = a_el
                    break

        existing_abstract_ids = [
            int(a.get(qn("w:abstractNumId"))) for a in dest_root.findall(qn("w:abstractNum"))
        ]
        new_abstract_id = str(max(existing_abstract_ids, default=-1) + 1)

        existing_num_ids = [
            int(n.get(qn("w:numId"))) for n in dest_root.findall(qn("w:num"))
        ]
        new_num_id = str(max(existing_num_ids, default=0) + 1)

        if src_abstract is not None:
            new_abstract = copy.deepcopy(src_abstract)
            new_abstract.set(qn("w:abstractNumId"), new_abstract_id)
            _insert_abstract_num(dest_root, new_abstract)

        new_num = copy.deepcopy(src_num)
        new_num.set(qn("w:numId"), new_num_id)
        new_num_abstract_ref = new_num.find(qn("w:abstractNumId"))
        if new_num_abstract_ref is not None:
            new_num_abstract_ref.set(qn("w:val"), new_abstract_id)
        dest_root.append(new_num)

        num_id_map[key] = new_num_id
        numId_el.set(qn("w:val"), new_num_id)


def batch_extract(folder, start_text, end_text, output_path):
    output_name = os.path.basename(output_path)
    files = sorted(glob.glob(os.path.join(folder, "*.docx")))
    files = [f for f in files if not os.path.basename(f).startswith("~$")]
    files = [f for f in files if os.path.basename(f) != output_name]

    if not files:
        print(f"No .docx files found in {folder}")
        sys.exit(1)

    master = Document()
    master_body = master.element.body
    sect_pr = master_body.find(qn("w:sectPr"))

    found_count = 0
    missing = []
    num_id_map = {}

    for f in files:
        src_doc, elements = get_section_elements(f, start_text, end_text)
        filename = os.path.basename(f)

        if elements is None:
            missing.append(filename)
            continue

        found_count += 1

        marker = master.add_paragraph()
        run = marker.add_run(f"Source report: {filename}")
        run.bold = True

        for el in elements:
            new_el = copy.deepcopy(el)
            copy_images(src_doc, master, new_el)
            copy_numbering(src_doc, master, new_el, num_id_map)
            if sect_pr is not None:
                sect_pr.addprevious(new_el)
            else:
                master_body.append(new_el)

        master.add_paragraph()

    master.save(output_path)

    print(f"\nDone. Extracted from {found_count}/{len(files)} files.")
    if missing:
        print(f"\nNo '{start_text}' heading found in {len(missing)} file(s):")
        for m in missing:
            print(f"  - {m}")
    print(f"\nSaved combined document to: {output_path}")


if __name__ == "__main__":
    start_text = sys.argv[1] if len(sys.argv) > 1 else "Medium Severity"
    end_text = sys.argv[2] if len(sys.argv) > 2 else "Low Severity"

    output_name = input("Enter output filename (e.g. Combined_Medium_Severity.docx): ").strip()
    if not output_name:
        output_name = "Combined_Output.docx"
    if not output_name.lower().endswith(".docx"):
        output_name += ".docx"

    batch_extract(".", start_text, end_text, output_name)
