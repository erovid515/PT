#!/usr/bin/env python3
"""
extract_medium_severity.py

Scans every .docx in a folder, finds the "Medium Severity Vulnerabilities"
heading in each, and extracts everything from that heading up to (but not
including) the next heading whose text is "Low Severity Vulnerabilities" —
matched purely by heading TEXT, not by numbering or Word outline level.
This means any sub-finding under Medium Severity (e.g. "Unrestricted File
Upload") is included even if Word tagged it with the same style/level as
the "Medium Severity Vulnerabilities" heading itself.

Images, tables, formatting, and any existing list numbering inside the
extracted content are preserved as-is. The script does NOT add its own
section/heading numbering to the combined output — each extracted block is
simply preceded by a line naming the source report.

Usage:
    python3 extract_medium_severity.py <input_folder> <output.docx>

Example:
    python3 extract_medium_severity.py . combined_medium_severity.docx
"""

import copy
import os
import re
import sys

from docx import Document
from docx.oxml.ns import qn
from docx.text.paragraph import Paragraph

# ---------------------------------------------------------------------------
# Config: adjust these two strings if your report uses slightly different
# wording. Matching is case-insensitive and ignores a leading number/prefix
# like "6.2.3 " before the heading text.
# ---------------------------------------------------------------------------
START_HEADING_TEXT = "medium severity vulnerabilities"
STOP_HEADING_TEXT = "low severity vulnerabilities"


def normalize_heading_text(text):
    """Lowercase, strip, and remove a leading numbering prefix such as
    '6.2.3 ', '6.2.3.1)', '6.2.3 -' etc., so matching relies on the words
    only, not on the numbering scheme."""
    text = text.strip().lower()
    text = re.sub(r"^[\d]+(\.[\d]+)*[\.\)\-:]?\s*", "", text)
    return text.strip()


def is_heading_paragraph(paragraph):
    style_name = (paragraph.style.name or "") if paragraph.style else ""
    return style_name.lower().startswith("heading") or style_name.lower() == "title"


def iter_block_items(document):
    """Yield each top-level child element (paragraph or table) of the body,
    in document order, as raw lxml elements."""
    body = document.element.body
    for child in body.iterchildren():
        tag = child.tag
        if tag == qn("w:p") or tag == qn("w:tbl"):
            yield child


def find_section_elements(document):
    """Return the list of raw XML elements between the start heading
    (inclusive) and the stop heading (exclusive). Returns None if the
    start heading isn't found in this document."""
    elements = list(iter_block_items(document))

    start_idx = None
    stop_idx = None

    for idx, el in enumerate(elements):
        if el.tag != qn("w:p"):
            continue
        para = Paragraph(el, document)
        if not is_heading_paragraph(para):
            continue
        norm = normalize_heading_text(para.text)

        if start_idx is None:
            if norm == START_HEADING_TEXT:
                start_idx = idx
            continue

        if norm == STOP_HEADING_TEXT:
            stop_idx = idx
            break

    if start_idx is None:
        return None

    if stop_idx is None:
        stop_idx = len(elements)

    return elements[start_idx:stop_idx]


# ---------------------------------------------------------------------------
# Cross-document copying helpers: images and numbering definitions need to
# be re-linked/re-registered in the destination document, otherwise copied
# paragraphs will reference relationship IDs / numIds that don't exist
# there (broken images, wrong or missing list numbering).
# ---------------------------------------------------------------------------

def _add_image_get_rid(dst_doc, image_bytes):
    """Register raw image bytes as a new image part in dst_doc and return
    the new relationship id. Tries the modern python-docx API first and
    falls back to older/alternate method names so this works across
    python-docx versions."""
    import io
    part = dst_doc.part
    if hasattr(part, "get_or_add_image"):
        rid, _image = part.get_or_add_image(io.BytesIO(image_bytes))
        return rid
    if hasattr(part, "get_or_add_image_part"):
        result = part.get_or_add_image_part(io.BytesIO(image_bytes))
        if isinstance(result, tuple):
            first, second = result
            return second if isinstance(second, str) else first
        return result
    raise RuntimeError(
        "Installed python-docx version doesn't expose get_or_add_image "
        "or get_or_add_image_part — run: pip install --upgrade python-docx"
    )


def copy_images(src_doc, dst_doc, element):
    """Rewrite every image reference inside `element` (both modern
    DrawingML pictures via a:blip, and legacy VML images via v:imagedata)
    so it points at a copy of the image inserted into dst_doc."""
    # Modern DrawingML images
    for blip in element.iter(qn("a:blip")):
        for attr in (qn("r:embed"), qn("r:link")):
            rid = blip.get(attr)
            if not rid:
                continue
            try:
                image_part = src_doc.part.related_parts[rid]
            except KeyError:
                continue
            new_rid = _add_image_get_rid(dst_doc, image_part.blob)
            blip.set(attr, new_rid)

    # Legacy VML images (rare, but some pasted/older screenshots use this).
    try:
        vml_tag = qn("v:imagedata")
    except KeyError:
        vml_tag = None
    if vml_tag is not None:
        for imagedata in element.iter(vml_tag):
            rid = imagedata.get(qn("r:id"))
            if not rid:
                continue
            try:
                image_part = src_doc.part.related_parts[rid]
            except KeyError:
                continue
            new_rid = _add_image_get_rid(dst_doc, image_part.blob)
            imagedata.set(qn("r:id"), new_rid)


def copy_numbering(src_doc, dst_doc, element, numid_map):
    """Copy the abstractNum/num definitions used by any numbered/bulleted
    paragraphs inside `element` from src_doc's numbering part into
    dst_doc's, remapping numId so lists render correctly and don't clash
    with numbering already used elsewhere in the combined document.
    `numid_map` caches (src_doc id, old_numId) -> new_numId across calls."""
    src_numbering = src_doc.part.numbering_part.element if src_doc.part.numbering_part else None
    dst_numbering_part = dst_doc.part.numbering_part
    if src_numbering is None or dst_numbering_part is None:
        return
    dst_numbering = dst_numbering_part.element

    for numpr in element.iter(qn("w:numPr")):
        numid_el = numpr.find(qn("w:numId"))
        if numid_el is None:
            continue
        old_numid = numid_el.get(qn("w:val"))
        key = (id(src_doc), old_numid)
        if key in numid_map:
            numid_el.set(qn("w:val"), numid_map[key])
            continue

        src_num = None
        for num in src_numbering.findall(qn("w:num")):
            if num.get(qn("w:numId")) == old_numid:
                src_num = num
                break
        if src_num is None:
            continue

        abstract_num_id_el = src_num.find(qn("w:abstractNumId"))
        old_abstract_id = abstract_num_id_el.get(qn("w:val")) if abstract_num_id_el is not None else None

        src_abstract = None
        if old_abstract_id is not None:
            for abstract in src_numbering.findall(qn("w:abstractNum")):
                if abstract.get(qn("w:abstractNumId")) == old_abstract_id:
                    src_abstract = abstract
                    break

        existing_num_ids = [
            int(n.get(qn("w:numId"))) for n in dst_numbering.findall(qn("w:num"))
            if n.get(qn("w:numId")) and n.get(qn("w:numId")).isdigit()
        ]
        existing_abstract_ids = [
            int(a.get(qn("w:abstractNumId"))) for a in dst_numbering.findall(qn("w:abstractNum"))
            if a.get(qn("w:abstractNumId")) and a.get(qn("w:abstractNumId")).isdigit()
        ]
        new_abstract_id = str(max(existing_abstract_ids, default=0) + 1)
        new_num_id = str(max(existing_num_ids, default=0) + 1)

        if src_abstract is not None:
            new_abstract = copy.deepcopy(src_abstract)
            new_abstract.set(qn("w:abstractNumId"), new_abstract_id)
            dst_numbering.append(new_abstract)

        new_num = copy.deepcopy(src_num)
        new_num.set(qn("w:numId"), new_num_id)
        new_abstract_ref = new_num.find(qn("w:abstractNumId"))
        if new_abstract_ref is not None:
            new_abstract_ref.set(qn("w:val"), new_abstract_id)
        dst_numbering.append(new_num)

        numid_map[key] = new_num_id
        numid_el.set(qn("w:val"), new_num_id)


def append_report_label(dst_doc, filename):
    p = dst_doc.add_paragraph()
    run = p.add_run(f"Report: {filename}")
    run.bold = True
    p.style = dst_doc.styles["Heading 1"] if "Heading 1" in [s.name for s in dst_doc.styles] else p.style


def process_folder(input_folder, output_path):
    combined = Document()
    if combined.paragraphs and not combined.paragraphs[0].text:
        p_el = combined.paragraphs[0]._p
        p_el.getparent().remove(p_el)

    numid_map = {}
    found_any = False

    docx_files = sorted(
        f for f in os.listdir(input_folder)
        if f.lower().endswith(".docx") and not f.startswith("~$")
    )

    if not docx_files:
        print(f"No .docx files found in {input_folder}")
        return

    for filename in docx_files:
        path = os.path.join(input_folder, filename)
        print(f"Processing: {filename}")
        try:
            src_doc = Document(path)
        except Exception as e:
            print(f"  Skipped (could not open): {e}")
            continue

        section_elements = find_section_elements(src_doc)
        if not section_elements:
            print(f"  '{START_HEADING_TEXT}' heading not found — skipping")
            continue

        found_any = True
        append_report_label(combined, filename)

        for el in section_elements:
            new_el = copy.deepcopy(el)
            copy_images(src_doc, combined, new_el)
            copy_numbering(src_doc, combined, new_el, numid_map)
            combined.element.body.append(new_el)

        print(f"  Extracted {len(section_elements)} block(s)")

    if not found_any:
        print("Nothing extracted from any document — output not written.")
        return

    combined.save(output_path)
    print(f"\nCombined document saved to: {output_path}")


if __name__ == "__main__":
    if len(sys.argv) != 3:
        print(f"Usage: python3 {os.path.basename(sys.argv[0])} <input_folder> <output.docx>")
        sys.exit(1)

    input_folder = sys.argv[1]
    output_path = sys.argv[2]
    process_folder(input_folder, output_path)
